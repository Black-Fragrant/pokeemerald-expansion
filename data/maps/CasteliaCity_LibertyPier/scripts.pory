mapscripts CasteliaCity_LibertyPier_MapScripts {}

script CasteliaCity_LibertyPier_EventScript_Youngster
{
    msgbox("Aren't Pokémon great?\p"
        "Even if they're fightin' someone\n"
        "bigger than them, up and at 'em they go!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_LibertyPier_EventScript_Veteran
{
    msgbox("Hahaha!\n"
    "Strength is not in the size of a body.\p"
    "It's in the size of the heart!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_LibertyPier_EventScript_Captain
{
    lock
    faceplayer
    goto_if_set(FLAG_CASTELIA_LIBERTY_PIER_CHECKED_TICKET, CasteliaCity_LibertyPier_EventScript_Captain_ReCheckTicket)
    goto_if_set(FLAG_CASTELIA_POKEMON_CENTER_LIBERTY_PASS, CasteliaCity_LibertyPier_EventScript_Captain_CheckTicket)
    msgbox("It is small compared to a luxury liner,\n"
        "but the size of a ship doesn't change\l"
        "the feeling of adventure when you're\l"
        "out on the open sea.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_LP_CAPTAIN)
    goto(CasteliaCity_LibertyPier_EventScript_Captain_CloseMessage)
}

script CasteliaCity_LibertyPier_EventScript_Captain_CloseMessage
{
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_CASTELIA_LP_CAPTAIN, moves(walk_in_place_down))
    waitmovement(0)
    release
    end
}

script CasteliaCity_LibertyPier_EventScript_Captain_CheckTicket
{
    setflag(FLAG_CASTELIA_LIBERTY_PIER_CHECKED_TICKET)
    msgbox("Oh! You have a Liberty Pass.\p"
        "Would you like to go to Liberty Garden?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_LP_CAPTAIN)
    goto_if_eq(VAR_RESULT, TRUE, CasteliaCity_LibertyPier_EventScript_Captain_Warp)
    goto(CasteliaCity_LibertyPier_EventScript_Captain_NoGo)
}

script CasteliaCity_LibertyPier_EventScript_Captain_NoGo
{
    msgbox("If you'd like to go to Liberty Garden,\n"
            "Please let me know.", MSGBOX_DEFAULT)
    goto(CasteliaCity_LibertyPier_EventScript_Captain_CloseMessage)
}

script CasteliaCity_LibertyPier_EventScript_Captain_ReCheckTicket
{
    setflag(FLAG_CASTELIA_LIBERTY_PIER_CHECKED_TICKET)
    msgbox("Would you like to go to Liberty Garden?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_LP_CAPTAIN)
    goto_if_eq(VAR_RESULT, TRUE, CasteliaCity_LibertyPier_EventScript_Captain_Warp)
    goto(CasteliaCity_LibertyPier_EventScript_Captain_NoGo)
}

script CasteliaCity_LibertyPier_EventScript_Captain_Warp
{
    msgbox("Your timing is perfect.\n"
            "The ship is about to leave.\l"
            "Please get aboard ship and wait.", MSGBOX_DEFAULT)
    destroy_speech_bubble()
    closemessage
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 15, CasteliaCity_LibertyPier_EventScript_Warp_Pos1)
	call_if_eq (VAR_TEMP_0, 16, CasteliaCity_LibertyPier_EventScript_Warp_Pos2)
    delay(10)
	warp (MAP_LIBERTY_GARDEN, 6, 11)
	waitstate
    release
    end
}

script CasteliaCity_LibertyPier_EventScript_Warp_Pos1
{
    applymovement(LOCALID_PLAYER, moves(walk_in_place_down))
    waitmovement(0)
    return
}

script CasteliaCity_LibertyPier_EventScript_Warp_Pos2
{
    applymovement(LOCALID_PLAYER, moves(walk_left, walk_down))
    waitmovement(0)
    return
}
