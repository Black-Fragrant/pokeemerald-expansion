script CasteliaCity_PokeCenter_EventScript_Blacksuit_Ending
{
	msgbox("What are the Pokémon that I traded\n"
		"doing now?\p"
		"What are the people who traded with me\n"
		"thinking about now?\p"
		"Thinking about those things\n"
		"makes me happy!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_POKECEN_BLACKSUIT)
	destroy_speech_bubble()
	closemessage
	clearflag(FLAG_TEMP_11)
	release
	end
}

script CasteliaCity_PokeCenter_EventScript_Breeder
{
	lock
	faceplayer
	goto_if_set(FLAG_CASTELIA_POKEMON_CENTER_BREEDER_MOVE, CasteliaCity_PokeCenter_EventScript_Breeder_AskAboutGeonet)
	msgbox("Wanna recover Pokemon?\n"
		"Oh, soooooorry!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_POKECEN_BREEDER)
	destroy_speech_bubble()
	closemessage
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 5, CasteliaCity_PokeCenter_EventScript_Breeder_MoveRight)
	call_if_eq (VAR_TEMP_0, 6, CasteliaCity_PokeCenter_EventScript_Breeder_MoveRight)
	call_if_eq (VAR_TEMP_0, 7, CasteliaCity_PokeCenter_EventScript_Breeder_MoveLeft)
	goto(CasteliaCity_PokeCenter_EventScript_Breeder_AskAboutGeonet)
}

script CasteliaCity_PokeCenter_EventScript_Breeder_AskAboutGeonet
{
	msgbox("Do you know Geonet?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_POKECEN_BREEDER)
	goto_if_eq(VAR_RESULT, YES, CasteliaCity_PokeCenter_EventScript_Breeder_Yes)
	destroy_speech_bubble()
	closemessage
	applymovement(LOCALID_CASTELIA_POKECEN_BREEDER, moves(walk_in_place_up))
	waitmovement(0)
	delay(10)
	msgbox("You see the globe on the second floor\n"
		"of this Pokemon Center?\p"
		"That is Geonet.\p"
		"If you check on Geonet, you can register\n"
		"the place where you live!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_POKECEN_BREEDER)
	destroy_speech_bubble()
	closemessage
	setflag(FLAG_CASTELIA_POKEMON_CENTER_BREEDER_MOVE)
	release
	end
}

script CasteliaCity_PokeCenter_EventScript_Breeder_Yes
{
	destroy_speech_bubble()
	closemessage
	msgbox("Oh! You know Geonet!\n"
		"Great, great!\p"
		"This is even greater, lemme tell ya!\p"
		"If you try Geonet, you can register\n"
		"the place where you live!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_POKECEN_BREEDER)
	destroy_speech_bubble()
	closemessage
	setflag(FLAG_CASTELIA_POKEMON_CENTER_BREEDER_MOVE)
	release
	end
}

script CasteliaCity_PokeCenter_EventScript_Breeder_MoveRight
{
	applymovement(LOCALID_CASTELIA_POKECEN_BREEDER, moves(walk_right * 2, walk_in_place_left))
	waitmovement(0)
	return
}
script CasteliaCity_PokeCenter_EventScript_Breeder_MoveLeft
{
	applymovement(LOCALID_CASTELIA_POKECEN_BREEDER, moves(walk_left * 2, walk_in_place_right))
	waitmovement(0)
	return
}

