script CasteliaCity_PokeCenter_EventScript_Traded_5to9
{
	buffernumberstring(STR_VAR_1, VAR_TIMES_YOU_HAVE_TRADED)
	msgbox("Wow!\n"
		"You have traded with {STR_VAR_1} people!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_POKECEN_BLACKSUIT)
	destroy_speech_bubble()
	closemessage
	call_if_unset(FLAG_CASTELIA_POKEMON_CENTER_ITEM_WIDE_LENS, CasteliaCity_PokeCenter_EventScript_Give_WideLens)
