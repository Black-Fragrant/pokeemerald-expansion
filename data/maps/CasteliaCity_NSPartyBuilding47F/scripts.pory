mapscripts CasteliaCity_NSPartyBuilding47F_MapScripts 
{
	MAP_SCRIPT_ON_FRAME_TABLE
    [
        VAR_CASTELIA_INSIDE_ELEVATORS, 1 : CasteliaCity_NSPartyBuilding47F_EventScript_NewToFloor
    ]
}

script CasteliaCity_NSPartyBuilding47F_EventScript_NewToFloor
{
	lockall()
	playse(SE_DING_DONG)
	waitse()
    delay (20)
	playse(SE_SLIDING_DOOR)
	setdooropen(7, 2)
	waitse()
    delay (10)
	applymovement(LOCALID_PLAYER, moves(walk_down * 2))
	waitmovement(0)
    delay (20)
	playse(SE_SLIDING_DOOR)
	setdoorclosed(7, 2)
	waitse()
    setvar(VAR_CASTELIA_INSIDE_ELEVATORS, 0)
    delay (10)
    releaseall()
    end
}

script CasteliaCity_NSPartyBuilding47F_EventScript_Gentleman
{
    msgbox("Welcome!\n"
           "Welcome to my party!\p"
           "Please enjoy conversations\n"
           "with everyone!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_NSPartyBuilding47F_EventScript_CheerleaderMan
{
    msgbox("Ich habe mir nun ein Auto zugelegt!\p"
           "Damit ist die nächste Stadt auch\n"
           "ganz ohne Orden zum Greifen nah!\p"
           "Es sei denn, ich rassle durch\n"
           "meine Führerscheinprüfung...", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_NSPartyBuilding47F_EventScript_BeardMan
{
