{
	trainerbattle_no_intro (TRAINER_BIANCA_CASTELIA_GATE_2, text("I trained with Iris...\nBut I still couldn't win..."))
	return()
}

script CasteliaCity_Gate_EventScript_BiancaBattle_Tepig
{
	trainerbattle_no_intro (TRAINER_BIANCA_CASTELIA_GATE_3, text("I trained with Iris...\nBut I still couldn't win..."))
	return()
}

