}

script Route3_North_EventScript_Trigger_TryLeaving
{
	lock
	applymovement(LOCALID_ROUTE3N_BIANCA, moves(face_left))
	waitmovement(0)
	playse(SE_PIN)
	applymovement(LOCALID_ROUTE3N_BIANCA, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 45, Route3_North_EventScript_Trigger_TryLeaving_Pos1)
	call_if_eq (VAR_TEMP_0, 46, Route3_North_EventScript_Trigger_TryLeaving_Pos2)
	call_if_eq (VAR_TEMP_0, 47, Route3_North_EventScript_Trigger_TryLeaving_Pos3)
	delay(10)
	applymovement(LOCALID_PLAYER, moves(walk_in_place_up))
	waitmovement(0)
	msgbox("Bianca: Please, {PLAYER}.\p"
       "Team Plasma took that Pokémon.\n"
       "Get it back!", MSGBOX_DEFAULT, TRUE, LOCALID_ROUTE3N_BIANCA)
	destroy_speech_bubble()
	closemessage
	delay(10)
	applymovement(LOCALID_PLAYER, moves(walk_up))
	applymovement(LOCALID_ROUTE3N_BIANCA, moves(walk_up))
	waitmovement(0)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 45, Route3_North_EventScript_Trigger_TryLeaving_Pos4)
	call_if_eq (VAR_TEMP_0, 46, Route3_North_EventScript_Trigger_TryLeaving_Pos5)
	call_if_eq (VAR_TEMP_0, 47, Route3_North_EventScript_Trigger_TryLeaving_Pos6)
	delay(10)
	release
	end
}

