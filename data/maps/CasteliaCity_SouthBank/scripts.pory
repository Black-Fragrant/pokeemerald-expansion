script CasteliaCity_SouthBank_EventScript_OL_ByThumbPier
{
    msgbox("Castelia City has so many people!\p"
        "Sometimes there are folks who only\n"
        "care about themselves.", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_SouthBank_EventScript_Businessman_ByCasteliaStreet
{
    msgbox("Busy, busy!\p"
        "After I eat breakfast, I have to think\n"
        "about lunch.\p"
        "After eating lunch, I worry about dinner.\n"
        "Every day's the same. What a busy life!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_SouthBank_EventScript_Businessman_ByCruiseDock
{
