mapscripts CasteliaCity_BattleCompany1F_MapScripts {}

script CasteliaCity_BattleCompany1F_EventScript_Trigger
{
	lock
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_up * 2))
	waitmovement(0)
	special(RemoveCameraObject)
	playse(SE_PIN)
	applymovement(LOCALID_BATTLE_COMPANY_1F_GRANDPA, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 6, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos1)
	call_if_eq (VAR_TEMP_0, 7, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos2)
	call_if_eq (VAR_TEMP_0, 8, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos3)
    delay(10)
    msgbox("People who work in this building have\n"
        "Pokemon battles, not opinion battles.\p"
        "You appear to be strong, but if you go\n"
        "upstairs, please be extra careful.", MSGBOX_DEFAULT, TRUE, LOCALID_BATTLE_COMPANY_1F_GRANDPA)
    destroy_speech_bubble()
    closemessage
    delay(10)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 6, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos4)
	call_if_eq (VAR_TEMP_0, 7, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos5)
	call_if_eq (VAR_TEMP_0, 8, CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos6)
	delay(20)
	playse(SE_DING_DONG)
	waitse()
    delay (10)
	playse(SE_SLIDING_DOOR)
	setdooropen(7, 2)
	waitse()
    delay (10)
	applymovement(LOCALID_BATTLE_COMPANY_1F_GRANDPA, moves(walk_right, walk_up * 2))
	waitmovement(0)
    delay (20)
	playse(SE_SLIDING_DOOR)
	setdoorclosed(7, 2)
	waitse()
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_down * 6))
	waitmovement(0)
	special(RemoveCameraObject)
    setvar(VAR_CASTELIA_BATTLE_COMPANY_STATE, 1)
    removeobject(LOCALID_BATTLE_COMPANY_1F_GRANDPA)
    setflag(FLAG_CASTELIA_BATTLE_COMPANY_1F_GRANDPA)
    delay(20)
    release
    end
}

script CasteliaCity_BattleCompany1F_EventScript_Trigger_Pos1
{
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_down * 2))
	applymovement(LOCALID_BATTLE_COMPANY_1F_GRANDPA, moves(walk_left, walk_down * 2))
	waitmovement(0)
	special(RemoveCameraObject)
    return
}

