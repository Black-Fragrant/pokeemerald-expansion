script CasteliaGym_HoneyWallPass
{
    specialvar(VAR_RESULT, GetPlayerFacingDirection)
    goto_if_eq(VAR_RESULT, DIR_NORTH, CasteliaGym_HoneyWallPass_FromBelow)
    goto_if_eq(VAR_RESULT, DIR_SOUTH, CasteliaGym_HoneyWallPass_FromAbove)
    call(CasteliaGym_HoneyWallBounce)
    return
}

script CasteliaGym_HoneyWallPass_FromBelow
{
    special(StartHoneyWallHoldUp)
    waitstate
    goto_if_eq(VAR_RESULT, TRUE, CasteliaGym_HoneyWallPass_FromBelowSuccess)
    goto(CasteliaGym_HoneyWallPass_FromBelowFailure)
}

script CasteliaGym_HoneyWallPass_FromAbove
{
    special(StartHoneyWallHoldDown)
    waitstate
    goto_if_eq(VAR_RESULT, TRUE, CasteliaGym_HoneyWallPass_FromAboveSuccess)
    goto(CasteliaGym_HoneyWallPass_FromAboveFailure)
}

script CasteliaGym_HoneyWallPlayWiggle
{
    special(StartHoneyWallWiggle)
    playse(SE_MUD_BALL)
    return
}

script CasteliaGym_PlayHoneyWallBounceSe
{
    // Placeholder SFX until final Castelia Gym bounce audio is chosen.
    playse(SE_WALL_HIT)
    return
}

script CasteliaGym_HoneyWallPass_FromBelowSuccess
{
    call(CasteliaGym_HoneyWallPlayWiggle)
    applymovement(LOCALID_PLAYER, moves(lock_facing_direction, jump_2_up, unlock_facing_direction, face_up))
    waitstate
    waitmovement(0)
    goto(CasteliaGym_HoneyWallPass_Finish)
}

script CasteliaGym_HoneyWallPass_FromBelowFailure
{
    call(CasteliaGym_HoneyWallPlayWiggle)
    call(CasteliaGym_PlayHoneyWallBounceSe)
    applymovement(LOCALID_PLAYER, moves(face_up, lock_facing_direction, jump_down, unlock_facing_direction, face_up))
    waitstate
    waitmovement(0)
    goto(CasteliaGym_HoneyWallPass_Finish)
}

script CasteliaGym_HoneyWallPass_FromAboveSuccess
{
    call(CasteliaGym_HoneyWallPlayWiggle)
    showplayer
    applymovement(LOCALID_PLAYER, moves(lock_facing_direction, jump_2_down, unlock_facing_direction, face_down))
    waitstate
    waitmovement(0)
    goto(CasteliaGym_HoneyWallPass_Finish)
}

script CasteliaGym_HoneyWallPass_FromAboveFailure
{
    call(CasteliaGym_HoneyWallPlayWiggle)
    call(CasteliaGym_PlayHoneyWallBounceSe)
    applymovement(LOCALID_PLAYER, moves(face_down, lock_facing_direction, jump_up, unlock_facing_direction, face_down))
    waitstate
    waitmovement(0)
    goto(CasteliaGym_HoneyWallPass_Finish)
}

script CasteliaGym_HoneyWallPass_Finish
{
    special(RestoreHoneyWallIdle)
    return
}

script CasteliaGym_HoneyWallBounce
{
    call(CasteliaGym_HoneyWallPlayWiggle)
    call(CasteliaGym_PlayHoneyWallBounceSe)
    call(CasteliaGym_HoneyWallBounceMovement)
    waitstate
    waitmovement(0)
    special(RestoreHoneyWallIdle)
    return
}

script CasteliaGym_HoneyWallBounceMovement
{
    special(Special_CasteliaGym_GetHoneyWallBounceDirection)
    goto_if_eq(VAR_RESULT, DIR_NORTH, CasteliaGym_HoneyWallBounceUp)
    goto_if_eq(VAR_RESULT, DIR_SOUTH, CasteliaGym_HoneyWallBounceDown)
    goto(CasteliaGym_HoneyWallBounceDown)
}

script CasteliaGym_HoneyWallBounceDown
{
    applymovement(LOCALID_PLAYER, moves(face_up, lock_facing_direction, jump_down, unlock_facing_direction, face_up))
    return
}

script CasteliaGym_HoneyWallBounceUp
{
    applymovement(LOCALID_PLAYER, moves(face_down, lock_facing_direction, jump_up, unlock_facing_direction, face_down))
    return
}

script CasteliaGym_HoneyWallCenterClosed
{
    call(CasteliaGym_HoneyWallBounce)
    release
    end
}

