script CasteliaGym_Button5
{
    lock
    goto_if_set(FLAG_CASTELIA_GYM_BUTTON_5_A, CasteliaGym_ButtonAlreadyPressed)
    call(CasteliaGym_PlayButtonPressSe)
    setflag(FLAG_CASTELIA_GYM_BUTTON_5_A)
    call(CasteliaGym_ButtonGroupAPanToLights)
    call(CasteliaGym_Button5ALightsOn)
    setmetatile (16, 18, 0x291, FALSE)
    special(DrawWholeMapView)
    call(CasteliaGym_PlayLightOnSe)
    call(CasteliaGym_UpdateGatesAfterLightOn)
