script CasteliaCity_CasteliaGym_Eventscripy_NoTriggering
{
    return
}

script CasteliaCity_CasteliaGym_Eventscripy_Button1
{
    lock
    playse(SE_SUCCESS)
    delay(8)
    playse(SE_SUCCESS)
    waitse
    setvar(VAR_CASTELIA_GYM_SWITCH_1, 1)
    call(CasteliaCity_CasteliaGym_Eventscripy_Button1isTriggered)
	special(DrawWholeMapView)
    call(CasteliaCity_CasteliaGym_Eventscripy_RedrawGate5)
	special(DrawWholeMapView)
    call(CasteliaCity_CasteliaGym_Eventscripy_RedrawGate6)
	special(DrawWholeMapView)
    release
    end
}

