script CasteliaCity_CasteliaGym_Eventscript_BagIsFull
{
	msgbox(gText_TooBadBagIsFull, MSGBOX_TRANSPARENT)
	closemessage
	release()
	end()
}

script CasteliaCity_CasteliaGym_Eventscript_BagIsFull2
{
	msgbox(gText_TooBadBagIsFull, MSGBOX_TRANSPARENT)
	closemessage
	return()
}
