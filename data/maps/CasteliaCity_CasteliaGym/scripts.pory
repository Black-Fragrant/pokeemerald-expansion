script CasteliaCity_CasteliaGym_Eventscripy_RedrawGate1
{
	goto_if_eq(VAR_CASTELIA_GYM_SWITCH_6, 0, CasteliaCity_CasteliaGym_Eventscripy_NoTriggering)
	goto_if_eq(VAR_CASTELIA_GYM_SWITCH_8, 0, CasteliaCity_CasteliaGym_Eventscripy_NoTriggering)
	setmetatile (15, 13, 0x2C5, FALSE)
	setmetatile (16, 13, 0x2C6, FALSE)
	setmetatile (17, 13, 0x2C7, FALSE)
	setmetatile (15, 14, 0x2B5, FALSE)
	setmetatile (16, 14, 0x2B6, FALSE)
	setmetatile (17, 14, 0x2B7, FALSE)
	setmetatile (15, 15, 0x2BD, FALSE)
	setmetatile (16, 15, 0x2BE, FALSE)
	setmetatile (17, 15, 0x2BF, FALSE)
    return
}

