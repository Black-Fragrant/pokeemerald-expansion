mapscripts PinwheelForest_Inside_MapScripts 
{
    MAP_SCRIPT_ON_TRANSITION : PinwheelForest_Inside_On_Transition
}

script PinwheelForest_Inside_On_Transition
{
	call_if_ge (VAR_NACRENE_STATE, 8, PinwheelForest_Inside_EventScript_PlayMusic)
    end()
}

script PinwheelForest_Inside_EventScript_PlayMusic
{
	goto_if_ge (VAR_NACRENE_STATE, 10, PinwheelForest_Inside_EventScript_PlayMusic_Intercept)
    savebgm(MUS_BW_APPEARS_PLASMA_2)
    return
}

script PinwheelForest_Inside_EventScript_PlayMusic_Intercept
{
    return
}

script PinwheelForest_Inside_SignPost_TrainerTips_Bottom
{
	msgbox("Trainer Tips!\p"
           "A forest is likely to contain many\n"
           "well-hidden items!\p"
           "They may be hard to find,\n"
           "so look carefully!", MSGBOX_SIGN)
	end
}

script PinwheelForest_Inside_EventScript_TPG_Blocking_1
{
    lock
    msgbox("In order to eliminate the old-fashioned\n"
           "ways of looking at things...", MSGBOX_DEFAULT, TRUE)
    destroy_speech_bubble()
    closemessage
    release
	end
}

script PinwheelForest_Inside_EventScript_TPG_Blocking_2
{
    lock
    msgbox("We will steal Pokémon!\n"
           "You'll never play together again!", MSGBOX_DEFAULT, TRUE)
    destroy_speech_bubble()
    closemessage
    release
	end
}

