script PinwheelForest_Inside_Trigger_TPGF_Battle_2
{
    lock
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_1, 55, PinwheelForest_ITTB2_CameraDown)
	call_if_eq (VAR_TEMP_1, 56, PinwheelForest_ITTB2_CameraDown)
	call_if_eq (VAR_TEMP_1, 64, PinwheelForest_ITTB2_CameraUp)
	call_if_eq (VAR_TEMP_1, 65, PinwheelForest_ITTB2_CameraUp)
	playse(SE_PIN)
	applymovement(LOCALID_PFI_TPGF_B2, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    playbgm(MUS_BW_SPOTTED_PLASMA, TRUE)
    savebgm(MUS_BW_APPEARS_PLASMA_2)
	call_if_eq (VAR_TEMP_1, 55, PinwheelForest_ITTB2_Pos1)
	call_if_eq (VAR_TEMP_1, 56, PinwheelForest_ITTB2_Pos2)
	call_if_eq (VAR_TEMP_1, 57, PinwheelForest_ITTB2_Pos3)
	call_if_eq (VAR_TEMP_1, 58, PinwheelForest_ITTB2_Pos4)
	call_if_eq (VAR_TEMP_1, 59, PinwheelForest_ITTB2_Pos5)
	call_if_eq (VAR_TEMP_1, 61, PinwheelForest_ITTB2_Pos6)
	call_if_eq (VAR_TEMP_1, 62, PinwheelForest_ITTB2_Pos7)
	call_if_eq (VAR_TEMP_1, 63, PinwheelForest_ITTB2_Pos8)
	call_if_eq (VAR_TEMP_1, 64, PinwheelForest_ITTB2_Pos9)
	call_if_eq (VAR_TEMP_1, 65, PinwheelForest_ITTB2_Pos10)
    delay(10)
    msgbox("Team Plasma: My, my.\n"
           "Could you be looking for something?", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_TPGF_B2)
    destroy_speech_bubble()
    closemessage
    trainerbattle_no_intro(TRAINER_GRUNT_F_PF_INSIDE, text("My hunch is you're sabotaging us\nbecause you're flat-out jealous\lof our cool outfits."))
    setvar(VAR_PINWHEEL_FOREST_STATE, 2)
    goto(PinwheelForest_Inside_EventScript_TPGF_2_Cont)
}

script PinwheelForest_Inside_EventScript_TPGF_2
{
    lock
    faceplayer
    goto(PinwheelForest_Inside_EventScript_TPGF_2_Cont)
}

script PinwheelForest_Inside_EventScript_TPGF_2_Cont
{
    msgbox("Team Plasma: Sorry!\n"
           "I'm empty handed.\p"
           "Do I look like the kind of girl\n"
           "to carry a heavy load?\p"
           "Better try somewhere else!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_TPGF_B2)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script PinwheelForest_ITTB2_CameraDown
{
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_fast_down * 2))
	waitmovement(0)
	special(RemoveCameraObject)
    return
}

