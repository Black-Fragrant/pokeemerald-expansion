script PinwheelForest_Inside_Trigger_TPGM_Battle_1
{
    lock
	playse(SE_PIN)
	applymovement(LOCALID_PFI_TPGM_B1, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    playbgm(MUS_BW_SPOTTED_PLASMA, TRUE)
    savebgm(MUS_BW_APPEARS_PLASMA_2)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 59, PinwheelForest_ITTB1_Pos1)
	call_if_eq (VAR_TEMP_0, 61, PinwheelForest_ITTB1_Pos2)
	call_if_eq (VAR_TEMP_0, 62, PinwheelForest_ITTB1_Pos3)
    delay(10)
    msgbox("Team Plasma: You stubborn brat!\p"
           "When I'm through with you,\n"
           "you won't be able to chase us anymore!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_TPGM_B1)
    destroy_speech_bubble()
    closemessage
    trainerbattle_no_intro(TRAINER_GRUNT_M_PF_INSIDE_1, text("Come on!\nYou're just a kid--a kid on an ego trip!"))
    setvar(VAR_PINWHEEL_FOREST_STATE, 1)
    goto(PinwheelForest_Inside_EventScript_TPGM_1_Cont)
}

script PinwheelForest_Inside_EventScript_TPGM_1
{
    lock
    faceplayer
    goto(PinwheelForest_Inside_EventScript_TPGM_1_Cont)
}

script PinwheelForest_Inside_EventScript_TPGM_1_Cont
{
    msgbox("Team Plasma: Too bad!\n"
           "I haven't got anything!\p"
           "If you want to get it back,\n"
           "you're just gonna have\l"
           "to look for my associates!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_TPGM_B1)
    destroy_speech_bubble()
    closemessage
    release
    end
}

