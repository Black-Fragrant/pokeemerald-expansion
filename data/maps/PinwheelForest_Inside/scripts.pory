script PinwheelForest_Inside_EventScript_Battle_Ranger_M_1
{
	trainerbattle_single(TRAINER_RANGER_M_PF_INSIDE_1,
	text("I patrol Pinwheel Forest every day!\n"
           "A battle here is a piece of cake!"),
	text("What a huge mistake to lose\n"
           "a battle in Pinwheel Forest!"),
	PinwheelForest_Inside_EventScript_Ranger_M_GivesChestoBerry)
	goto(PinwheelForest_Inside_EventScript_Ranger_M_GivesChestoBerry)
	end()
}

script PinwheelForest_Inside_EventScript_Ranger_M_GivesChestoBerry
{
	goto_if_set(FLAG_PINWHEEL_FOREST_I_ITEM_CHESTO_BERRY, PinwheelForest_Inside_EventScript_Ranger_M_ChestoReceived)
	msgbox("A Ranger always has one of these.\n"
           "I'll give it to you!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_RANGER_M_CHESTO)
	destroy_speech_bubble()
	closemessage
	giveitem(ITEM_CHESTO_BERRY, 1)
	goto_if_eq (VAR_RESULT, FALSE, PinwheelForest_Inside_EventScript_BagIsFull)
	goto (PinwheelForest_Inside_EventScript_Ranger_M_ChestoReceived)
	end
}

script PinwheelForest_Inside_EventScript_Ranger_M_ChestoReceived
{
	msgbox("The forest is alive...\p"
           "Something changes every day,\n"
           "so it's fun to patrol!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_RANGER_M_CHESTO)
	destroy_speech_bubble()
	closemessage
	setflag(FLAG_PINWHEEL_FOREST_I_ITEM_CHESTO_BERRY)
	release()
	end()
}

