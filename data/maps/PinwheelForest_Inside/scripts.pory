script PinwheelForest_Inside_EventScript_Battle_Schoolboy
{
	trainerbattle_single(TRAINER_SCHOOLBOY_PF_INSIDE,
	text("Why do Pokémon and people\n"
           "stay together...?\l"
           "That's the theme of my research."),
	text("A ray of light shone in...\n"
           "I feel a little like that."))
	msgbox("Why do Pokémon and people\n"
           "stay together...?\p"
           "I think we stick together\n"
           "because we are different.", MSGBOX_NPC, TRUE)
	end()
}

script PinwheelForest_Inside_EventScript_Battle_Lass
{
	trainerbattle_single(TRAINER_LASS_PF_INSIDE,
	text("Look, look! This is a Gym Badge\n"
           "from Striaton City!\p"
           "Oh, you have it, too!\n"
           "Then let's have a Pokémon battle\l"
           "to see who is stronger!"),
	text("Impressive! A battle with a\n"
           "Gym Badge holder is different!"))
	msgbox("You know, there's a pedestal at the\n"
           "entrance of each Pokémon Gym.\p"
           "If you get that Gym's Badge,\n"
           "your name will be carved there.", MSGBOX_NPC, TRUE)
	end()
}

script NacreneCity_EventScript_Scientist_F_Bridge
{
	msgbox("Have you heard of phytoncides?\p"
