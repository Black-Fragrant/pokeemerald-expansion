script PinwheelForest_Inside_Trigger_Entrance_Burgh
{
    lock
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 71, PinwheelForest_ITEB_Pos1)
	call_if_eq (VAR_TEMP_0, 72, PinwheelForest_ITEB_Pos2)
	call_if_eq (VAR_TEMP_0, 74, PinwheelForest_ITEB_Pos3)
	call_if_eq (VAR_TEMP_0, 75, PinwheelForest_ITEB_Pos4)
	call_if_eq (VAR_TEMP_0, 76, PinwheelForest_ITEB_Pos5)
    delay(10)
    msgbox("Burgh: Well, you see...\p"
           "There are two ways out of\n"
           "Pinwheel Forest--\p"
           "the road that goes straight and the\n"
           "path that winds through the woods.", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_ENTRANCE)
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_PFI_BURGH_ENTRANCE, moves(walk_in_place_up))
    waitmovement(0)
    delay(10)
    msgbox("I will take the straight road after them!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_ENTRANCE)
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_PFI_BURGH_ENTRANCE, moves(face_down))
    waitmovement(0)
    msgbox("If they're not there,\n"
           "I'll block the exit.", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_ENTRANCE)
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_PFI_BURGH_ENTRANCE, moves(walk_in_place_left))
    waitmovement(0)
    delay(10)
    msgbox("Would you please take the other way\n"
           "and check whether Team Plasma\l"
           "is hiding in there somewhere?\p"
           "You'll run into a lot of Trainers,\n"
           "but it's basically a single path,\l"
           "so I'm sure you won't get lost.", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_ENTRANCE)
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_PFI_BURGH_ENTRANCE, moves(face_down))
    waitmovement(0)
    msgbox("Come on!\n"
           "Let's do this for Lenora's sake!", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_ENTRANCE)
    destroy_speech_bubble()
    closemessage
    delay(10)
    applymovement(LOCALID_PFI_BURGH_ENTRANCE, moves(walk_up * 5))
    waitmovement(0)
    removeobject(LOCALID_PFI_BURGH_ENTRANCE)
    setflag(FLAG_PINWHEEL_FOREST_I_BURGH_ENTRANCE)
    setvar(VAR_NACRENE_STATE, 9)
    delay(20)
    release
    end
}

