script PinwheelForest_Inside_Trigger_Exit_Burgh
{
    lock
	playse(SE_PIN)
	applymovement(LOCALID_PFI_BURGH_EXIT, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 71, PinwheelForest_ITExB_Pos1)
	call_if_eq (VAR_TEMP_0, 72, PinwheelForest_ITExB_Pos2)
	call_if_eq (VAR_TEMP_0, 73, PinwheelForest_ITExB_Pos3)
	call_if_eq (VAR_TEMP_0, 75, PinwheelForest_ITExB_Pos4)
	call_if_eq (VAR_TEMP_0, 76, PinwheelForest_ITExB_Pos5)
    applymovement(LOCALID_PFI_BURGH_EXIT, moves(walk_in_place_down))
    waitmovement(0)
    delay(10)
    msgbox("Burgh: Mm-hmm?\p"
           "Team Plasma hasn't come\n"
           "in this direction...\p"
           "The forest's bug Pokémon are quiet, too.", MSGBOX_DEFAULT, TRUE, LOCALID_PFI_BURGH_EXIT)
    destroy_speech_bubble()
    closemessage
    applymovement(LOCALID_PLAYER, moves(walk_down))
    waitmovement(0)
    delay(10)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 71, PinwheelForest_ITExB_Pos6)
	call_if_eq (VAR_TEMP_0, 72, PinwheelForest_ITExB_Pos7)
	call_if_eq (VAR_TEMP_0, 73, PinwheelForest_ITExB_Pos8)
	call_if_eq (VAR_TEMP_0, 75, PinwheelForest_ITExB_Pos9)
	call_if_eq (VAR_TEMP_0, 76, PinwheelForest_ITExB_Pos10)
    delay(10)
    release
    end
}

