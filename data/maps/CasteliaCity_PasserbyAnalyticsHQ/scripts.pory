script CasteliaCity_PAHQ_EventScript_Beauty_MoreQuestionnaires
{
    call(CasteliaCity_PAHQ_EventScript_Beauty_Intro)
    call(CasteliaCity_PAHQ_EventScript_AskForMoreQuestionnaires)
    destroy_speech_bubble()
    closemessage
	goto_if_eq (VAR_RESULT, FALSE, CasteliaCity_PAHQ_EventScript_NoAnsweringQuestionnaires)
    goto_if_unset(FLAG_ADDED_SURVEY_POKEMON_FAVORITES, CasteliaCity_PAHQ_EventScript_Beauty_Survey2_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_IDEALS_AND_VALUES, CasteliaCity_PAHQ_EventScript_Beauty_Survey3_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_LIKABLE_PEOPLE, CasteliaCity_PAHQ_EventScript_Beauty_Survey4_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_PREFERENCES, CasteliaCity_PAHQ_EventScript_Beauty_Survey5_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_ENTERTAINMENT, CasteliaCity_PAHQ_EventScript_Beauty_Survey6_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_SCHOOL_LIFE, CasteliaCity_PAHQ_EventScript_Beauty_Survey7_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_SPORTS_AND_PASTIMES, CasteliaCity_PAHQ_EventScript_Beauty_Survey8_Cont)
    goto_if_unset(FLAG_ADDED_SURVEY_MORE_ABOUT_POKEMON, CasteliaCity_PAHQ_EventScript_Beauty_Survey9_Cont)
    msgbox("Oh? It looks like you've answered\n"
       "all the questionnaires.\p"
       "Would you like to re-answer\n"
       "the questionnaires you did before?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
	goto_if_eq (VAR_RESULT, FALSE, CasteliaCity_PAHQ_EventScript_Beauty_FinishingWords)
    msgbox("Then, will you choose a questionnaire\n"
       "you'd like to answer?", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
	scrollingmultichoice(4, 20, 0, 6, 1)
    destroy_speech_bubble()
    closemessage
	if (var(VAR_RESULT) == 0) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey1_Cont)}
	elif (var(VAR_RESULT) == 1) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey2_Cont)}
	elif (var(VAR_RESULT) == 2) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey3_Cont)}
	elif (var(VAR_RESULT) == 3) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey4_Cont)}
	elif (var(VAR_RESULT) == 4) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey5_Cont)}
	elif (var(VAR_RESULT) == 5) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey6_Cont)}
	elif (var(VAR_RESULT) == 6) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey7_Cont)}
	elif (var(VAR_RESULT) == 7) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey8_Cont)}
	elif (var(VAR_RESULT) == 8) {goto (CasteliaCity_PAHQ_EventScript_Beauty_Survey9_Cont)}
    goto(CasteliaCity_PAHQ_EventScript_Beauty_FinishingWords)
}

script CasteliaCity_PAHQ_EventScript_Beauty_GivesSodaPop
{
    msgbox("This is the end of\n"
        "all the questionnaires.\p"
        "It was fun to get to know you!\p"
        "And... This is a thank-you gift\n"
        "for answering the questionnaire.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
	giveitem(ITEM_SODA_POP, 1)
	goto_if_eq (VAR_RESULT, FALSE, CasteliaCity_PAHQ_EventScript_BagIsFull)
    setflag(FLAG_CASTELIA_PAHQ_OBTAINED_SODA_POP)
    goto(CasteliaCity_PAHQ_EventScript_Beauty_FinishingWords)
}

