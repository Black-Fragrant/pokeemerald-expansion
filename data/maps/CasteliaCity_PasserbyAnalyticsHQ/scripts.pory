script CasteliaCity_PAHQ_EventScript_Beauty
{
    lock
    faceplayer
    goto_if_set(FLAG_CASTELIA_PAHQ_OBTAINED_SODA_POP, CasteliaCity_PAHQ_EventScript_Beauty_MoreQuestionnaires)
    goto_if_set(FLAG_ADDED_SURVEY_MORE_ABOUT_POKEMON, CasteliaCity_PAHQ_EventScript_Beauty_GivesSodaPop)
    goto_if_set(FLAG_ADDED_SURVEY_DETAILS_ABOUT_PEOPLE, CasteliaCity_PAHQ_EventScript_Beauty_MoreQuestionnaires)
    goto_if_set(FLAG_CASTELIA_PAHQ_BECAME_STATISTICIAN, CasteliaCity_PAHQ_EventScript_Beauty_Survey1)
    msgbox("This is Passerby Analytics HQ.\p"
       "If you want to join us,\n"
       "please speak to the leader.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
    release    
    end
}

script CasteliaCity_PAHQ_EventScript_Beauty_Survey1
{
    call(CasteliaCity_PAHQ_EventScript_Beauty_Intro)
    msgbox("Actually, I have a favor to ask you.\p"
        "I'm asking statisticians to answer\n"
        "a questionnaire.\p"
        "OK, here we go!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
    goto(CasteliaCity_PAHQ_EventScript_Beauty_Survey1_Cont)
}

script CasteliaCity_PAHQ_EventScript_Beauty_Survey1_Cont
{
    call(CasteliaCity_PAHQ_EventScript_Beauty_LetsGetStarted)
    msgbox("is about\n"
        "“Details about people.”\p"
        "“What is your hobby?”", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
	scrollingmultichoice(0, 20, 0, 6, 0)
	copyvar(VAR_PAHQ_HOBBY_SURVEY_RESULT, VAR_RESULT)
    destroy_speech_bubble()
    closemessage
    call(CasteliaCity_PAHQ_EventScript_Beauty_ISeeISee)
    msgbox("“What is your job?”", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
	scrollingmultichoice(1, 20, 0, 6, 0)
	copyvar(VAR_PAHQ_JOB_SURVEY_RESULT, VAR_RESULT)
    destroy_speech_bubble()
    closemessage
    call(CasteliaCity_PAHQ_EventScript_Beauty_ThatIsIt)
    goto_if_set(FLAG_CASTELIA_PAHQ_OBTAINED_SODA_POP, CasteliaCity_PAHQ_EventScript_Beauty_FinishingWords)
    call(CasteliaCity_PAHQ_EventScript_Beauty_GiveThisToYouToo)
    setflag(FLAG_ADDED_SURVEY_DETAILS_ABOUT_PEOPLE)
    playse(SE_PIN)
    msgbox("The “Details About People” survey\n"
       "was added to the Survey Radar!", MSGBOX_TRANSPARENT)
    closemessage
    waitse
    buffernumberstring(STR_VAR_1, 8)
    call(CasteliaCity_PAHQ_EventScript_CalculateNumbersOfSurveysLeft)
    call(CasteliaCity_PAHQ_EventScript_AskForMoreQuestionnairesContinue)
    destroy_speech_bubble()
    closemessage
	goto_if_eq (VAR_RESULT, YES, CasteliaCity_PAHQ_EventScript_Beauty_Survey2_Cont)
    goto(CasteliaCity_PAHQ_EventScript_AnsweredNoForMoreQuestionnaires)
}

