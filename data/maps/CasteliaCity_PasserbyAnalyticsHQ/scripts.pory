script CasteliaCity_PAHQ_EventScript_BagIsFull
{
	msgbox(gText_TooBadBagIsFull, MSGBOX_TRANSPARENT)
	closemessage
	release()
	end()
}

script CasteliaCity_PAHQ_EventScript_Trigger
{
    lock
    setvar(VAR_PAHQ_STATE, 0)
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_fast_up * 4))
	waitmovement(0)
	special(RemoveCameraObject)
    playse(SE_LEDGE)
	applymovement(LOCALID_CASTELIA_PAHQ_BEAUTY, moves(jump_in_place_down))
	waitmovement(0)
    waitse
    playse(SE_LEDGE)
	applymovement(LOCALID_CASTELIA_PAHQ_BEAUTY, moves(jump_in_place_down))
	waitmovement(0)
    waitse
    msgbox("Excuse me, new statistician!\n"
           "Please wait!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_fast_down * 4))
	waitmovement(0)
	special(RemoveCameraObject)
	applymovement(LOCALID_PLAYER, moves(walk_up * 3, walk_left * 1, walk_up * 3, walk_in_place_left))
	waitmovement(0)
	applymovement(LOCALID_CASTELIA_PAHQ_BEAUTY, moves(walk_in_place_right))
	waitmovement(0)
    delay(10)
    msgbox("Actually, I have a favor to ask you.\p"
           "I'm asking statisticians to answer\n"
           "a questionnaire.\p"
           "OK, here we go!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_BEAUTY)
    destroy_speech_bubble()
    closemessage
    goto(CasteliaCity_PAHQ_EventScript_Beauty_Survey1_Cont)
}
