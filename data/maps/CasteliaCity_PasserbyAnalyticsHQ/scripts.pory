mapscripts CasteliaCity_PasserbyAnalyticsHQ_MapScripts {}

script CasteliaCity_PAHQ_EventScript_Chart
{
    lock
    goto_if_set(FLAG_CASTELIA_PAHQ_BECAME_STATISTICIAN, CasteliaCity_PAHQ_EventScript_Chart_ShowStats)
	msgbox("STATISTICIANS WANTED!\n"
       "FOR DETAILS, ASK THE LEADER!", MSGBOX_TRANSPARENT)
    closemessage
    release
	end
}

script CasteliaCity_PAHQ_EventScript_Chart_ShowStats
{
	msgbox("STATS IN PREPARATION...\n"
       "CHECK BACK LATER!", MSGBOX_TRANSPARENT)
    closemessage
    release
	end
}

script CasteliaCity_PAHQ_EventScript_RichGirl
{
    lock
    faceplayer
    goto_if_set(FLAG_CASTELIA_PAHQ_TALKED_TO_RICHGIRL_ONCE, CasteliaCity_PAHQ_EventScript_RichGirl_Repeat)
    setflag(FLAG_CASTELIA_PAHQ_TALKED_TO_RICHGIRL_ONCE)
    msgbox("Hello! Do you always have a feeling\n"
       "of gratitude?\p"
       "Oh, you dropped your Poké Ball.\n"
       "Here you are.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_RICHGIRL)
    destroy_speech_bubble()
    closemessage
    msgbox("{PLAYER} received a Pokémon Ball.", MSGBOX_TRANSPARENT)
    closemessage
    msgbox("Please remember to thank someone\n"
       "who helps you!\p"
       "It may sound trivial, but it's important.\p"
       "Now, will you tell me your\n"
       "feeling of gratitude?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_PAHQ_RICHGIRL)
	goto_if_eq (VAR_RESULT, YES, CasteliaCity_PAHQ_EventScript_RichGirl_Yes)
    goto(CasteliaCity_PAHQ_EventScript_RichGirl_No)
}

script CasteliaCity_PAHQ_EventScript_RichGirl_No
{
    destroy_speech_bubble()
    closemessage
    msgbox("Then, maybe next time.\p"
        "Don't forget a feeling of gratitude!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_RICHGIRL)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_RichGirl_Repeat
{
    msgbox("Hello! Do you always have a feeling\n"
       "of gratitude?\p"
       "If you don't mind, will you show me your\n"
       "feeling of gratitude again?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_PAHQ_RICHGIRL)
	goto_if_eq (VAR_RESULT, YES, CasteliaCity_PAHQ_EventScript_RichGirl_Yes)
    goto(CasteliaCity_PAHQ_EventScript_RichGirl_No)
}

script CasteliaCity_PAHQ_EventScript_RichGirl_Yes
{
    destroy_speech_bubble()
    closemessage
    special(DoExpressGratitude)
	waitstate
	specialvar(VAR_RESULT, TryBufferGratitudeWord)
    msgbox("{STR_VAR_1}\p"
        "What a wonderful phrase!\n"
       "It warms up my heart.\p"
       "If somebody helps you,\n"
       "show your feelings of gratitude.\p"
       "I am sure they will appreciate\n"
       "your feelings.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_RICHGIRL)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_Youngster
{
    lock
    faceplayer
    goto_if_set(FLAG_CASTELIA_PAHQ_TALKED_TO_YOUNGSTER_ONCE, CasteliaCity_PAHQ_EventScript_Youngster_Repeat)
    setflag(FLAG_CASTELIA_PAHQ_TALKED_TO_YOUNGSTER_ONCE)
    msgbox("Hello!\n"
        "Greeting is important, isn't it?\p"
        "If you don't mind, would you\n"
        "tell me your favorite greeting?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_PAHQ_YOUNGSTER)
	goto_if_eq (VAR_RESULT, YES, CasteliaCity_PAHQ_EventScript_Youngster_Yes)
    goto(CasteliaCity_PAHQ_EventScript_Youngster_No)
}

script CasteliaCity_PAHQ_EventScript_Youngster_No
{
    destroy_speech_bubble()
    closemessage
    msgbox("Then, maybe next time.\n"
       "Let's always have a cheerful greeting!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_YOUNGSTER)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_Youngster_Repeat
{
    msgbox("Hello!\n"
        "Greeting is important, isn't it?\p"
        "If you don't mind, would you tell me\n"
        "favorite greeting again?", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_PAHQ_YOUNGSTER)
	goto_if_eq (VAR_RESULT, YES, CasteliaCity_PAHQ_EventScript_Youngster_Yes)
    goto(CasteliaCity_PAHQ_EventScript_Youngster_No)
}

script CasteliaCity_PAHQ_EventScript_Youngster_Yes
{
    destroy_speech_bubble()
    closemessage
    special(DoGreetPeople)
	waitstate
	specialvar(VAR_RESULT, TryBufferGreetWord)
    msgbox("{STR_VAR_1}\p"
       "Yes, it's a good greeting!\n"
       "It cheers me up!\p"
       "Please feel free to come and say hi again!\n"
       "I look forward to seeing you again!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_YOUNGSTER)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_Scientist
{
    lock
    faceplayer
    goto_if_set(FLAG_CASTELIA_PAHQ_BECAME_STATISTICIAN, CasteliaCity_PAHQ_EventScript_Scientist_Cont)
    msgbox("What are people's favorite things?\n"
       "What is popular right now?\p"
       "Have you ever wondered about\n"
       "these things?\p"
       "Welcome to Passerby Analytics HQ!\p"
       "This is where you can find\n"
       "all the answers.\p"
       "…You have good eyes.\n"
       "Eyes full of curiosity.\p"
       "…Good! I will specially appoint you\n"
       "as a statistician!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    setflag(FLAG_CASTELIA_PAHQ_BECAME_STATISTICIAN)
    setvar(VAR_PAHQ_STATE, 1)
    msgbox("{PLAYER} was appointed\n"
       "as a statistician!", MSGBOX_TRANSPARENT)
    closemessage
    msgbox("Statisticians have only one task!\n"
       "They conduct requested surveys.\p"
       "First, you'll receive survey requests\n"
       "from me.\p"
       "Then, with the Survey Radar, you'll\n"
       "choose the survey you want to conduct.\p"
       "Then, if you pass by a lot of people,\n"
       "the radar will collect the information.\p"
       "Of course, we've prepared compensation\n"
       "for the survey.\p"
       "Statistician {PLAYER}!\n"
       "I expect you to do a great job!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    goto(CasteliaCity_PAHQ_EventScript_Scientist_Multichoice)
}

script CasteliaCity_PAHQ_EventScript_Scientist_Cont
{
    msgbox("Statistician {PLAYER},\n"
       "good to see you!\p"
       "Are you surveying people vigorously?", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    goto(CasteliaCity_PAHQ_EventScript_Scientist_Multichoice)
}

script CasteliaCity_PAHQ_EventScript_Scientist_Multichoice
{
    msgbox("What would you like to do today?", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
	multichoice(20, 0, MULTI_PAHQ_SCIENTIST, 0)
	if (var(VAR_RESULT) == 0) {goto (CasteliaCity_PAHQ_EventScript_AcceptARequest)}
	elif (var(VAR_RESULT) == 1) {goto (CasteliaCity_PAHQ_EventScript_Scientist_ReportTheResult)}
    destroy_speech_bubble()
    closemessage
    msgbox("I see…\p"
       "I'm lonely, so\n"
       "please come visit me sometimes.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_AcceptARequest
{
    destroy_speech_bubble()
    closemessage
    msgbox("We are still preparing for the surveys.\p"
        "Please check back with us shortly!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    release
    end
}

script CasteliaCity_PAHQ_EventScript_Scientist_ReportTheResult
{
    destroy_speech_bubble()
    closemessage
    msgbox("You don't seem to have accepted\n"
       "a survey request.\p"
       "Please come back if you want to\n"
       "accept a request.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_PAHQ_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    release
    end
}

