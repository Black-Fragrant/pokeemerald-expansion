script CasteliaCity_StudioCastelia_EventScript_Peirro
{
    lock
    faceplayer
	dotimebasedevents
	call_if_unset(FLAG_DAILY_STUDIO_CASTELIA_REROLL, CasteliaCity_StudioCastelia_EventScript_Peirro_RandomizeTypes)
	goto_if_set(FLAG_CASTELIA_STUDIO_CASTELIA_BERRY, CasteliaCity_StudioCastelia_EventScript_Peirro_ObtainedBerries)
	call(CasteliaCity_StudioCastelia_EventScript_Peirro_TypeChecks)
    msgbox("I am not as good an artist as Burgh,\n"
           "but I have a liking for paintings.\p"
           "Let me see. Today, I'd like to paint\n"
           "{STR_VAR_1}-type Pokémon!\p"
           "Will you show me what kinds of Pokémon\n"
           "you have?\p"
           "Please show me a Pokémon that's\n"
           "{STR_VAR_1} type!", MSGBOX_YESNO, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	goto_if_eq(VAR_RESULT, TRUE, CasteliaCity_StudioCastelia_EventScript_CheckTypes)
	goto(CasteliaCity_StudioCastelia_EventScript_NoCheckTypes)
	end
}

script CasteliaCity_StudioCastelia_EventScript_Peirro_TypeChecks
{
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 0, CasteliaCity_StudioCastelia_EventScript_CheckType_Normal)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 1, CasteliaCity_StudioCastelia_EventScript_CheckType_Fighting)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 2, CasteliaCity_StudioCastelia_EventScript_CheckType_Flying)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 3, CasteliaCity_StudioCastelia_EventScript_CheckType_Poison)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 4, CasteliaCity_StudioCastelia_EventScript_CheckType_Ground)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 5, CasteliaCity_StudioCastelia_EventScript_CheckType_Rock)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 6, CasteliaCity_StudioCastelia_EventScript_CheckType_Bug)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 7, CasteliaCity_StudioCastelia_EventScript_CheckType_Ghost)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 8, CasteliaCity_StudioCastelia_EventScript_CheckType_Steel)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 9, CasteliaCity_StudioCastelia_EventScript_CheckType_Fire)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 10, CasteliaCity_StudioCastelia_EventScript_CheckType_Water)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 11, CasteliaCity_StudioCastelia_EventScript_CheckType_Grass)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 12, CasteliaCity_StudioCastelia_EventScript_CheckType_Electric)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 13, CasteliaCity_StudioCastelia_EventScript_CheckType_Psychic)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 14, CasteliaCity_StudioCastelia_EventScript_CheckType_Ice)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 15, CasteliaCity_StudioCastelia_EventScript_CheckType_Dragon)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 16, CasteliaCity_StudioCastelia_EventScript_CheckType_Dark)
	call_if_eq(VAR_STUDIO_CASTELIA_DAILY_TYPE, 17, CasteliaCity_StudioCastelia_EventScript_CheckType_Fairy)
	return
}

script CasteliaCity_StudioCastelia_EventScript_Peirro_RandomizeTypes
{
	setflag(FLAG_DAILY_STUDIO_CASTELIA_REROLL)
	clearflag(FLAG_CASTELIA_STUDIO_CASTELIA_BERRY)
    random(18)
	copyvar(VAR_STUDIO_CASTELIA_DAILY_TYPE, VAR_RESULT)
	return()
}

script CasteliaCity_StudioCastelia_EventScript_CheckTypes
{
	special(ChoosePartyMon)
	goto_if_ge(VAR_0x8004, PARTY_SIZE, CasteliaCity_StudioCastelia_EventScript_NoCheckTypes)
	specialvar(VAR_RESULT, ScriptGetPartyMonSpecies)
	goto_if_eq(VAR_RESULT, SPECIES_EGG, CasteliaCity_StudioCastelia_EventScript_IsAnEgg)
	special(DoesChosenMonMatchDailyType)
	goto_if_eq(VAR_RESULT, FALSE, CasteliaCity_StudioCastelia_EventScript_TypeNoMatch)
	msgbox("Oh! You have that type!\n"
           "I'm inspired!\p"
           "Thank you! As a token of my gratitude,\n"
           "which one would you like?", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
	dynmultichoice(20, 0, TRUE, 5, 0, DYN_MULTICHOICE_CB_NONE,
        "Cheri Berries",
        "Chesto Berries",
        "Pecha Berries",
        "Rawst Berries",
        "Aspear Berries")
    destroy_speech_bubble()
    closemessage
	if (var(VAR_RESULT) == 0) {goto (CasteliaCity_StudioCastelia_EventScript_CheriBerries)}
	elif (var(VAR_RESULT) == 1) {goto (CasteliaCity_StudioCastelia_EventScript_ChestoBerries)}
	elif (var(VAR_RESULT) == 2) {goto (CasteliaCity_StudioCastelia_EventScript_PechaBerries)}
	elif (var(VAR_RESULT) == 3) {goto (CasteliaCity_StudioCastelia_EventScript_RawstBerries)}
	elif (var(VAR_RESULT) == 4) {goto (CasteliaCity_StudioCastelia_EventScript_AspearBerries)}
	end
}

script CasteliaCity_StudioCastelia_EventScript_TypeNoMatch
{
	call(CasteliaCity_StudioCastelia_EventScript_Peirro_TypeChecks)
    msgbox("The Pokémon you chose is not the one\n"
           "I requested.\p"
           "What I want to paint is a Pokémon that's\n"
           "{STR_VAR_1} type!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	release
	end
}

script CasteliaCity_StudioCastelia_EventScript_CheriBerries
{
	msgbox("Five Cheri Berries!\n"
           "It's all yours now!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	giveitem(ITEM_CHERI_BERRY, 5)
	goto(CasteliaCity_StudioCastelia_EventScript_FinishGivingBerries)
}

