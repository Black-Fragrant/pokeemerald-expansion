script CasteliaCity_StudioCastelia_EventScript_FinishGivingBerries
{
	goto_if_eq (VAR_RESULT, FALSE, Common_EventScript_BagIsFull_EndScript)
	setflag(FLAG_CASTELIA_STUDIO_CASTELIA_BERRY)
    msgbox("Aww. You are the best!\n"
           "Please come back tomorrow, too!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	release
	end
}

script CasteliaCity_StudioCastelia_EventScript_Peirro_ObtainedBerries
{
    msgbox("As long as the artist enjoys creating\n"
           "an artwork, it doesn't matter if the\l"
           "result is judged as bad or good.", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	release
	end
}

script CasteliaCity_StudioCastelia_EventScript_NoCheckTypes
{
	call(CasteliaCity_StudioCastelia_EventScript_Peirro_TypeChecks)
    msgbox("If you catch a Pokémon that's\n"
           "{STR_VAR_1} type, please show it to me!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	release
	end
}

script CasteliaCity_StudioCastelia_EventScript_IsAnEgg
{
    msgbox("Oh!\n"
           "The shape of this Egg...\p"
           "Superb! It gives me chills!\n"
           "It's electrifying! It makes me tremble!\p"
           "Alas, even I cannot tell what type\n"
           "an Egg is!", MSGBOX_DEFAULT, TRUE, LOCALID_CASTELIA_STUDIO_PEIRRO)
    destroy_speech_bubble()
    closemessage
	release
	end
}

