script NacreneCity_Museum_Trigger_Heist
{
    lock
    msgbox("Lenora: Now, you wait!\n"
           "Enough fooling around!", MSGBOX_DEFAULT)
    closemessage
    delay(10)
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	call_if_eq (VAR_TEMP_0, 9, NacreneCity_Museum_Trigger_Heist_Left)
	call_if_eq (VAR_TEMP_0, 10, NacreneCity_Museum_Trigger_Heist_Middle)
	call_if_eq (VAR_TEMP_0, 11, NacreneCity_Museum_Trigger_Heist_Right)
	delay(10)
    msgbox("Team Plasma: So you've come, Gym Leader.\p"
           "We, Team Plasma, claim this museum's\n"
           "Dragon Skull in the name of\l"
           "Pokémon liberation!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_MUSEUM_PG3)
    destroy_speech_bubble()
    closemessage
	delay(10)
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_fast_down * 5))
	waitmovement(0)
	special(RemoveCameraObject)
    delay(10)
    msgbox("Team Plasma: To show you we're serious,\n"
           "we'll steal it right before your eyes!", MSGBOX_DEFAULT)
    closemessage
	applymovement(LOCALID_NACRENE_MUSEUM_PG3, moves(walk_in_place_slow_down))
	waitmovement(0)
	applymovement(LOCALID_NACRENE_MUSEUM_PG4, moves(walk_in_place_slow_down))
	waitmovement(0)
    msgbox("Team Plasma: Well, then, here's\n"
           "our smoke screen!", MSGBOX_DEFAULT)
    closemessage
	minimsg("Plasmaaaa!", 3, 3)
	delay(40)
	minimsg("Plasmaaaa!", 18, 9)
	delay(60)
	closeallminimessages
	applymovement(LOCALID_NACRENE_MUSEUM_PG1, moves(walk_in_place_slow_down))
	waitmovement(0)
	applymovement(LOCALID_NACRENE_MUSEUM_PG5, moves(walk_in_place_slow_down))
	waitmovement(0)
	applymovement(LOCALID_NACRENE_MUSEUM_PG2, moves(walk_in_place_slow_down))
	waitmovement(0)
	applymovement(LOCALID_NACRENE_MUSEUM_PG6, moves(walk_in_place_slow_down))
	waitmovement(0)
	delay(20)
	fadescreen(FADE_TO_BLACK)
	playse(SE_FLEE)
	waitse()
    removeobject(LOCALID_NACRENE_MUSEUM_PG1)
    removeobject(LOCALID_NACRENE_MUSEUM_PG2)
    removeobject(LOCALID_NACRENE_MUSEUM_PG3)
    removeobject(LOCALID_NACRENE_MUSEUM_PG4)
    removeobject(LOCALID_NACRENE_MUSEUM_PG5)
    removeobject(LOCALID_NACRENE_MUSEUM_PG6)
	fadescreen(FADE_FROM_BLACK)
    call(NacreneCity_Museum_EventScript_StolenDragoniteSkull)
	special(DrawWholeMapView)
    setvar(VAR_NACRENE_STATE, 6)
	special(SpawnCameraObject)
	applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_fast_up * 5))
	waitmovement(0)
	special(RemoveCameraObject)
    delay(10)
	playse(SE_PIN)
	applymovement(LOCALID_NACRENE_MUSEUM_LENORA, moves(emote_exclamation_mark))
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	applymovement(LOCALID_NACRENE_MUSEUM_LENORA, moves(walk_slow_down * 2))
	waitmovement(0)
    delay(10)
    msgbox("Lenora: What's going on?", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_MUSEUM_LENORA)
    destroy_speech_bubble()
    closemessage
	applymovement(LOCALID_NACRENE_MUSEUM_LENORA, moves(walk_fast_left * 5, walk_fast_down * 4))
	waitmovement(0)
    removeobject(LOCALID_NACRENE_MUSEUM_LENORA)
    setflag(FLAG_NACRENE_MUSEUM_TEAM_PLASMSA_GRUNTS)
	delay(20)
	applymovement(LOCALID_NACRENE_MUSEUM_SCIENTIST, moves(walk_in_place_left, walk_in_place_down))
	waitmovement(0)
    delay(10)
    msgbox("Hawes: Oh! Oh! We have to go after them!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_MUSEUM_SCIENTIST)
    destroy_speech_bubble()
    closemessage
    delay(20)
    release
    end
}

script NacreneCity_Museum_Trigger_Heist_Left
{
	applymovement(LOCALID_PLAYER, moves(walk_fast_down * 3))
	waitmovement(0)
    return
}

script NacreneCity_Museum_Trigger_Heist_Middle
{
	applymovement(LOCALID_PLAYER, moves(walk_fast_left, walk_fast_down * 3))
	waitmovement(0)
    return
}

script NacreneCity_Museum_Trigger_Heist_Right
{
	applymovement(LOCALID_PLAYER, moves(walk_fast_left * 2, walk_fast_down * 3))
	waitmovement(0)
    return
}


