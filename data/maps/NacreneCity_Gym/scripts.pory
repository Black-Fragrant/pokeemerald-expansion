mapscripts NacreneCity_Gym_MapScripts 
{
    MAP_SCRIPT_ON_LOAD : NacreneCity_Gym_On_Load
    MAP_SCRIPT_ON_TRANSITION : NacreneCity_Gym_Transition
    MAP_SCRIPT_ON_FRAME_TABLE
    [
        VAR_NACRENE_STATE, 3 : NacreneCity_Gym_EventScript_ReceptionistGivesWater
    ]
}

script NacreneCity_Gym_On_Load
{
	call_if_set(FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_HiddenStairCase)
	end()
}

script NacreneCity_Gym_EventScript_HiddenStairCase
{
    setmetatile (9, 12, 0x323, FALSE)
    setmetatile (10, 9, 0x200, FALSE)
    setmetatile (11, 9, 0x200, FALSE)
    setmetatile (12, 9, 0x2A3, FALSE)
    setmetatile (13, 9, 0x2A4, FALSE)
    setmetatile (14, 9, 0x2A5, FALSE)
    setmetatile (15, 9, 0x2A2, FALSE)
    setmetatile (10, 10, 0x200, FALSE)
    setmetatile (11, 10, 0x200, FALSE)
    setmetatile (12, 10, 0x2AB, TRUE)
    setmetatile (13, 10, 0x2AC, TRUE)
    setmetatile (14, 10, 0x2AD, TRUE)
    setmetatile (15, 10, 0x2AA, TRUE)
    setmetatile (10, 11, 0x31C, TRUE)
    setmetatile (11, 11, 0x31D, TRUE)
    setmetatile (12, 11, 0x258, TRUE)
    setmetatile (13, 11, 0x259, TRUE)
    setmetatile (14, 11, 0x25E, TRUE)
    setmetatile (15, 11, 0x25F, TRUE)
    setmetatile (10, 12, 0x324, TRUE)
    setmetatile (11, 12, 0x325, TRUE)
    setmetatile (12, 12, 0x277, FALSE)
    setmetatile (13, 12, 0x261, TRUE)
    setmetatile (14, 12, 0x266, TRUE)
    setmetatile (15, 12, 0x267, TRUE)

}

script NacreneCity_Gym_Transition
{
    goto_if_set (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_PositionSchoolgirlAndScientist_2)
    call_if_set (FLAG_NACRENE_GYM_FOUND_1ST_BOOK, NacreneCity_Gym_EventScript_PositionSchoolgirl_1)
    call_if_set (FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_HINT, NacreneCity_Gym_EventScript_PositionSchoolgirl_2)
    call_if_set (FLAG_NACRENE_GYM_FOUND_2ND_BOOK, NacreneCity_Gym_EventScript_PositionSchoolgirlAndScientist)
    call_if_set (FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_ANOTHER_HINT, NacreneCity_Gym_EventScript_PositionSchoolgirl_2)
    call_if_set (FLAG_NACRENE_GYM_SCIENTIST_CLIMB_DOWN, NacreneCity_Gym_EventScript_PositionScientist_1)
    call_if_set (FLAG_NACRENE_GYM_FOUND_3RD_BOOK, NacreneCity_Gym_EventScript_PositionSchoolgirl_1)
    call_if_set (FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_LAST_HINT, NacreneCity_Gym_EventScript_PositionSchoolgirl_2)
    call_if_set (FLAG_NACRENE_GYM_FOUND_4TH_BOOK, NacreneCity_Gym_EventScript_PositionSchoolgirl_2)
    call_if_set (FLAG_NACRENE_GYM_SCHOOLGIRL_CLIMB_DOWN, NacreneCity_Gym_EventScript_PositionSchoolgirl_3)
    end()
}

script NacreneCity_Gym_EventScript_PositionSchoolgirl_1
{
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_DOWN)
    return()
}

script NacreneCity_Gym_EventScript_PositionSchoolgirl_2
{
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_UP)
    return()
}

script NacreneCity_Gym_EventScript_PositionSchoolgirlAndScientist
{
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_DOWN)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCIENTIST, MOVEMENT_TYPE_FACE_DOWN)
    return()
}

script NacreneCity_Gym_EventScript_PositionScientist_1
{
    setobjectxyperm(LOCALID_NACRENE_GYM_SCIENTIST, 6, 8)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCIENTIST, MOVEMENT_TYPE_FACE_LEFT)
    return()
}

script NacreneCity_Gym_EventScript_PositionSchoolgirl_3
{
    setobjectxyperm(LOCALID_NACRENE_GYM_SCHOOLGIRL, 13, 14)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_LEFT)
    return()
}

script NacreneCity_Gym_EventScript_PositionSchoolgirlAndScientist_2
{
    setobjectxyperm(LOCALID_NACRENE_GYM_SCIENTIST, 6, 8)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCIENTIST, MOVEMENT_TYPE_FACE_LEFT)
    setobjectxyperm(LOCALID_NACRENE_GYM_SCHOOLGIRL, 13, 14)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_LEFT)
    end()
}

script NacreneCity_Gym_EventScript_ReceptionistGivesWater
{
    lockall
    setvar(VAR_NACRENE_STATE, 4)
	playse(SE_PIN)
	applymovement(LOCALID_NACRENE_GYM_GYMRECEPTIONIST, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	applymovement(LOCALID_NACRENE_GYM_GYMRECEPTIONIST, moves(walk_left * 2, walk_down * 2))
	waitmovement(0)
	delay(10)
    msgbox("A Pokémon Gym where a Leader waits for\n"
           "a challenger at the back of a museum...\l"
           "It has a great atmosphere, doesn't it?\p"
           "So... I will give this to you!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_GYMRECEPTIONIST)
    destroy_speech_bubble()
    closemessage()
	giveitem(ITEM_FRESH_WATER, 1)
	call_if_eq (VAR_RESULT, FALSE, NacreneCity_Gym_EventScript_BagIsFull)
    closemessage
    msgbox("All Trainers in this Gym use\n"
           "Normal-type Pokémon.\p"
           "This is just between you and me...\p"
           "Normal-type Pokémon are weak against\n"
           "Fighting-type Pokémon.\p"
           "Around here, Fighting-type Pokémon\n"
           "show up around Pinwheel Forest.\p"
           "Now, I will explain about the Gym itself!\p"
           "In this Pokémon Gym, if you answer\n"
           "questions hidden in books,\l"
           "you can move forward.\p"
           "For your information, the first book is\n"
           "“Nice to Meet You, Pokémon.”\p"
           "If you don't know where the book is,\n"
           "please ask anyone!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_GYMRECEPTIONIST)
    destroy_speech_bubble()
    closemessage()
    delay(10)
	applymovement(LOCALID_NACRENE_GYM_GYMRECEPTIONIST, moves(walk_up * 2, walk_right * 2, walk_in_place_down))
	waitmovement(0)
    delay(20)
    releaseall
    end
}

script NacreneCity_Gym_EventScript_Receptionist
{
    lock
	msgbox("All Trainers in this Gym use\n"
           "Normal-type Pokémon.\p"
           "This is just between you and me...\p"
           "Normal-type Pokémon are weak against\n"
           "Fighting-type Pokémon.\p"
           "Around here, Fighting-type Pokémon\n"
           "show up around Pinwheel Forest.\p"
           "Now, I will explain about the Gym itself!\p"
           "In this Pokémon Gym, if you answer\n"
           "questions hidden in books,\l"
           "you can move forward.\p"
           "For your information, the first book is\n"
           "“Nice to Meet You, Pokémon.”\p"
           "If you don't know where the book is,\n"
           "please ask anyone!", MSGBOX_NPC, TRUE)
    release
	end
}

script NacreneCity_Gym_EventScript_BagIsFull
{
	msgbox(gText_TooBadBagIsFull, MSGBOX_DEFAULT)
	return()
}

script NacreneCity_Gym_EventScript_GymSign
{
    goto_if_set(FLAG_BADGE02_GET, NacreneCity_Gym_EventScript_GymSign_AfterBadge)
	msgbox("Nacrene Pokémon Gym\p"
			"Gym Leader: Lenora\n"
			"Certified Trainers:", MSGBOX_SIGN)
	end
}

script NacreneCity_Gym_EventScript_GymSign_AfterBadge
{
	msgbox("Nacrene Pokémon Gym\p"
			"Gym Leader: Lenora\n"
			"Certified Trainers: {PLAYER}", MSGBOX_SIGN)
	end
}

script NacreneCity_Gym_EventScript_Battle_Schoolboy
{
	trainerbattle_single(TRAINER_SCHOOLBOY_NACRENE_GYM,
	text("I hang around Nacrene Gym all the time.\n"
           "People call me a bookworm.\p"
           "I'll warn you now... I am strong because\n"
           "I spend the entire day either\l"
           "reading books or training Pokémon."),
	text("I may be a bookworm,\n"
           "but I am not a bug Pokémon."))
	msgbox("My first recommendation is a book called\n"
           "“Nice to Meet You, Pokémon.”\p"
           "The bookshelves for children's books\n"
           "are close to the entrance.", MSGBOX_NPC, TRUE)
	end()
}

script NacreneCity_Gym_EventScript_Book_NoRead
{
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_NotTheBook
{
    msgbox("...\p"
           "This is not the book you're looking for.", MSGBOX_DEFAULT)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_AdventureOnRoute3
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Children's Book.”\p"
           "“Adventure on Route3”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    checkplayergender
    goto_if_eq (VAR_RESULT, FEMALE, NacreneCity_Gym_EventScript_Book_AdventureOnRoute3_Female)
    msgbox("It's a story about a boy with Pokémon\n"
           "embarking on a great adventure.\p"
           "Two boys and a girl are having\n"
           "adventures together.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NotTheBook)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_AdventureOnRoute3_Female
{
    msgbox("It's a story about a girl with Pokémon\n"
           "embarking on a great adventure.\p"
           "Two girls and a boy are having\n"
           "adventures together.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NotTheBook)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_SweetsForPokemon
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Children's Books.”\p"
           "“Sweets for Pokémon”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It describes delicious sweets made by\n"
           "heating Berries in a pot.\p"
           "There are sweets called “Poffins”\n"
           "made from Berries in the faraway\l"
           "Sinnoh region, and Pokémon love them!", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_3RD_BOOK, NacreneCity_Gym_EventScript_Book_NotTheBook)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_4TH_BOOK, NacreneCity_Gym_EventScript_Book_FourthMemo)
    goto(NacreneCity_Gym_EventScript_Book_FourthMemo_Cont)
    end
}

script NacreneCity_Gym_EventScript_Book_FourthMemo
{
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    setflag(FLAG_NACRENE_GYM_FOUND_4TH_BOOK)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(face_up))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_UP)
    goto(NacreneCity_Gym_EventScript_Book_FourthMemo_Cont)
}

script NacreneCity_Gym_EventScript_Book_FourthMemo_Cont
{
    msgbox("There is a memo on the cover...\p"
           "“Did you manage to get here\n"
           "without being tricked by the questions?\p"
           "Now, this is the last question!\p"
           "Q: From this bookshelf...\n"
           "Move two backward, move one to the left,\l"
           "Move two forward, move one to the right,\l"
           "and move one backward...\l"
           "Now, where is it?\p"
           "The hint is...\n"
           "Find it by yourself!”", MSGBOX_DEFAULT)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_ConnectTheDotsToDrawPokemon
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Children's Books.”\p"
           "“Connect the Dots to Draw Pokémon”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It's a connect-the-dots book with\n"
           "lots of Pokémon pictures.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NotTheBook)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_NiceToMeetYouPokemon
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Children's Books.”\p"
           "“Nice to Meet You, Pokémon!”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It's a fairy tale about a little boy\n"
           "who met a Pokémon for\l"
           "the first time in his life.\p"
           "He is with a small brown Pokémon.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_1ST_BOOK, NacreneCity_Gym_EventScript_Book_FirstMemo)
    goto(NacreneCity_Gym_EventScript_Book_FirstMemo_Cont)
    end
}

script NacreneCity_Gym_EventScript_Book_FirstMemo
{
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    setflag(FLAG_NACRENE_GYM_FOUND_1ST_BOOK)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(face_down))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_DOWN)
    goto(NacreneCity_Gym_EventScript_Book_FirstMemo_Cont)
}

script NacreneCity_Gym_EventScript_Book_FirstMemo_Cont
{
    msgbox("There is a memo between the pages...\p"
           "“Pokémon Trainers!\n"
           "I am the Gym Leader, Lenora!\p"
           "I hid four memos in this Library.\n"
           "Each of them has a question.\p"
           "Can you solve the questions and\n"
           "come find me?\p"
           "Now this is the first question!\p"
           "Q: What is the first Pokémon you met\n"
           "in this Gym?\p"
           "The hint is...\n"
           "on a bookshelf in the middle row!\p"
           "Now, try to find it!”", MSGBOX_DEFAULT)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_TheBiologyOfSnivy
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Pokémon.”\p"
           "“The Biology of Snivy”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It describes the biology of Snivy.\p"
           "If they expose their tails to the sun by\n"
           "basking in a sunny place, they are\n"
           "in the middle of photosynthesis.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NotTheBook)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_TheBiologyOfOshawott
{
    msgbox("This is the bookshelf\n"
           "for “Pokémon.”\p"
           "“The Biology of Oshawott”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It describes the biology of Oshawott.\p"
           "The scalchop on its belly is very hard\n"
           "and grows from its bellybutton.\p"
           "Oshawott use it as a tool.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NotTheBook)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_TheBiologyOfTepig
{
    msgbox("This is the bookshelf\n"
           "for “Pokémon.”\p"
           "“The Biology of Tepig”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It describes the biology of Tepig.\p"
           "Flame burns inside its body, and\n"
           "it gives off flame from its nostrils.\p"
           "When it's not well, it can give off\n"
           "only smoke.", MSGBOX_DEFAULT)
    goto_if_set(FLAG_NACRENE_GYM_FOUND_ALL_BOOKS, NacreneCity_Gym_EventScript_Book_NoRead)
    goto(NacreneCity_Gym_EventScript_Book_LastMemo)
    end
}

script NacreneCity_Gym_EventScript_Book_LastMemo
{
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    setflag(FLAG_NACRENE_GYM_FOUND_ALL_BOOKS)
    msgbox("There is a memo between the pages!\p"
           "“You've managed to get here. Well done!\p"
           "You seem to have wisdom as well as\n"
           "strength! I look forward to our battle!\p"
           "Gym Leader Lenora”", MSGBOX_DEFAULT)
	playse(SE_DOOR)
    msgbox("Click!", MSGBOX_DEFAULT)
	waitse()
    msgbox("There is a switch\n"
           "under the book!", MSGBOX_DEFAULT)
    closemessage()
    call(NacreneCity_Gym_EventScript_HiddenStairCase)
	special(DrawWholeMapView)
    msgbox("Wow!\n"
           "A hidden staircase!", MSGBOX_DEFAULT)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Book_TheBiologyOfPatrat
{
    lock
    msgbox("This is the bookshelf\n"
           "for “Pokémon.”\p"
           "“The Biology of Patrat”\n"
           "Do you want to read this book?", MSGBOX_YESNO)
	goto_if_eq (VAR_RESULT, NO, NacreneCity_Gym_EventScript_Book_NoRead)
    msgbox("It describes the biology of Patrat.\p"
           "They communicate with each other by\n"
           "movement of their tails. A Patrat raises\l"
           "its tail when it sees an enemy.", MSGBOX_DEFAULT)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_1ST_BOOK, NacreneCity_Gym_EventScript_Book_NotTheBook)
    goto_if_unset (FLAG_NACRENE_GYM_FOUND_2ND_BOOK, NacreneCity_Gym_EventScript_Book_SecondMemo)
    goto(NacreneCity_Gym_EventScript_Book_SecondMemo_Cont)
    end
}

script NacreneCity_Gym_EventScript_Book_SecondMemo
{
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    setflag(FLAG_NACRENE_GYM_FOUND_2ND_BOOK)
    applymovement(LOCALID_NACRENE_GYM_SCIENTIST, moves(face_down))
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(face_down))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCIENTIST, MOVEMENT_TYPE_FACE_DOWN)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_DOWN)
    goto(NacreneCity_Gym_EventScript_Book_SecondMemo_Cont)
}

script NacreneCity_Gym_EventScript_Book_SecondMemo_Cont
{
    msgbox("There is a memo on the back cover...\p"
           "“As I thought, that question was easy.\n"
           "Well, this is the second question!\p"
           "Q: Flame burns inside its body, and it\n"
           "gives off smoke from its head while\l"
           "it runs...\l"
           "What is this book?\p"
           "The hint is...\n"
           "Somebody may be reading.”", MSGBOX_DEFAULT)
    closemessage()
    release
    end
}

script NacreneCity_Gym_EventScript_Battle_Schoolgirl
{
    lock
    faceplayer
    goto_if_set(FLAG_NACRENE_GYM_SCHOOLGIRL_CLIMB_DOWN, NacreneCity_Gym_EventScript_Battle_Schoolgirl_End)
    goto_if_set(FLAG_NACRENE_GYM_FOUND_4TH_BOOK, NacreneCity_Gym_EventScript_Schoolgirl_SawLastMemo)
    goto_if_set(FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_LAST_HINT, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle_6)
    goto_if_set(FLAG_NACRENE_GYM_FOUND_3RD_BOOK, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle_5)
    goto_if_set(FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_ANOTHER_HINT, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle_4)
    goto_if_set(FLAG_NACRENE_GYM_FOUND_2ND_BOOK, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle_3)
    goto_if_set(FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_HINT, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle_2)
    goto_if_unset(FLAG_NACRENE_GYM_FOUND_1ST_BOOK, NacreneCity_Gym_EventScript_Schoolgirl_NoBattle)
    msgbox("Hello, Trainer!\p"
           "You've found a memo already, and you're\n"
           "looking for a book about Pokémon?\p"
           "Teehee! In fact, I am also reading a\n"
           "book about Pokémon. It's about Tepig.\p"
           "I wonder if the first Pokémon you met\n"
           "in this Gym was Tepig?", MSGBOX_YESNO, TRUE, LOCALID_NACRENE_GYM_SCHOOLGIRL)
	goto_if_eq (VAR_RESULT, YES, NacreneCity_Gym_EventScript_Battle_Schoolgirl_Cont)
    destroy_speech_bubble()
    closemessage()
    msgbox("Tee hee! OK!\p"
           "What was the Pokémon you battled\n"
           "at the entrance of the Gym?\p"
           "There's a hint on the bookshelf\n"
           "to the left!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_SCHOOLGIRL)
    destroy_speech_bubble()
    closemessage()
    setflag(FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_HINT)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(walk_in_place_up))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_UP)
    release
    end
}

script NacreneCity_Gym_EventScript_Battle_Schoolgirl_Cont
{
    destroy_speech_bubble()
    closemessage()
    msgbox("Tee hee! What a pity!\p"
           "The first Pokémon you met in this Gym\n"
           "was not Tepig!\p"
           "Try to remember the Pokémon you battled\n"
           "at the entrance of the Gym.\p"
           "There's a hint on the bookshelf\n"
           "to the left!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_SCHOOLGIRL)
    destroy_speech_bubble()
    closemessage()
    setflag(FLAG_NACRENE_GYM_SCHOOLGIRL_GAVE_HINT)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(walk_in_place_up))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_UP)
    release
    end
}

