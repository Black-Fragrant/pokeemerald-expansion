script NacreneCity_Gym_EventScript_Book_ThirdMemo
{
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
    setflag(FLAG_NACRENE_GYM_FOUND_3RD_BOOK)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(face_down))
    waitmovement(0)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_DOWN)
    goto(NacreneCity_Gym_EventScript_Book_ThirdMemo_Cont)
}

