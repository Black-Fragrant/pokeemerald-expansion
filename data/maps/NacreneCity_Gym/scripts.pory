script NacreneCity_Gym_EventScript_Battle_Scientist
{
    lock
    faceplayer
    goto_if_set(FLAG_NACRENE_GYM_SCIENTIST_CLIMB_DOWN, NacreneCity_Gym_EventScript_Scientist_NoBattle_2)
    goto_if_unset(FLAG_NACRENE_GYM_FOUND_2ND_BOOK, NacreneCity_Gym_EventScript_Scientist_NoBattle)
    msgbox("...Hmhm. I see.\p"
           "Oh! Did you find the memo and come here\n"
           "to look for this book?\p"
           "What does the memo say?\p"
           "“Flame burns inside its body, and it gives\n"
           "off smoke from its head while it runs.”\p"
           "I'm reading a book called\n"
           "“The Structure of a Locomotive.”\p"
           "Is this book the correct answer?", MSGBOX_YESNO, TRUE, LOCALID_NACRENE_GYM_SCIENTIST)
	goto_if_eq(VAR_RESULT, NO, NacreneCity_Gym_EventScript_Battle_Scientist_Cont)
    destroy_speech_bubble()
    closemessage()
    msgbox("Oh! That is correct!\p"
           "“Flame burns inside its body, and it gives\n"
           "off smoke from its head while it runs.”\p"
           "That's exactly how a locomotive looks!\n"
           "Well, I'll let you read this book.\p"
           "But, before that...\p"
           "It would be great for my research\n"
           "if we had a Pokémon battle.", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_SCIENTIST)
    destroy_speech_bubble()
    closemessage()
    goto(NacreneCity_Gym_EventScript_Battle_Scientist_Cont_2)
}

