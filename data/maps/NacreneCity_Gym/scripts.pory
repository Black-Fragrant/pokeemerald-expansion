script NacreneCity_Gym_EventScript_Schoolgirl_SawLastMemo_TheRealBattle
{
    trainerbattle_no_intro(TRAINER_SCHOOLGIRL_NACRENE_GYM, text("Oh, wow!\n"
           "I lost, but thanks for a great battle!"))
    msgbox("You'll meet the Gym Leader soon.\n"
           "This is the last book.\p"
           "Now! Read the last book!", MSGBOX_DEFAULT, TRUE, LOCALID_NACRENE_GYM_SCHOOLGIRL)
    destroy_speech_bubble()
    closemessage()
    delay(10)
    applymovement(LOCALID_PLAYER, moves(walk_left, walk_in_place_right))
    waitmovement(0)
    applymovement(LOCALID_NACRENE_GYM_SCHOOLGIRL, moves(walk_down * 2, walk_right, walk_in_place_left))
    waitmovement(0)
    setflag(FLAG_NACRENE_GYM_SCHOOLGIRL_CLIMB_DOWN)
    setobjectxyperm(LOCALID_NACRENE_GYM_SCHOOLGIRL, 13, 14)
    setobjectmovementtype (LOCALID_NACRENE_GYM_SCHOOLGIRL, MOVEMENT_TYPE_FACE_LEFT)
    delay(20)
    release
    end
}

