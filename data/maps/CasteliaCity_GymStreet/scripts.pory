mapscripts CasteliaCity_GymStreet_MapScripts {}

script CasteliaCity_GymStreet_EventScript_Businessman_Top
{
    msgbox("Being a Pokémon Trainer doesn't\n"
        "necessarily make someone stronger.\p"
        "But everyone can love their Pokémon\n"
        "and enjoy playing together.", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_GymStreet_EventScript_OfficeLady
{
    msgbox("My Pokémon is soooo cute!\p"
        "It always makes me feel better\n"
        "when I come home!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_GymStreet_EventScript_Businessman_Bottom
{
    msgbox("I have six Poké Balls in my Bag!\p"
        "But, really, what I want is\n"
        "Great Balls and Ultra Balls!\p"
        "You can't buy them at the Poké Mart\n"
        "until you've collected Badges, though.", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_GymStreet_EventScript_AceTrainer
{
    msgbox("Before challenging the Gym, you'll want\n"
        "to be sure you have enough Potions.", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_GymStreet_EventScript_Veteran
{
    msgbox("What Gym Leaders test is the strength\n"
        "of the bond between the challenger\l"
        "and his or her Pokémon!", MSGBOX_NPC, TRUE)
    end
}

script CasteliaCity_GymStreet_EventScript_GymSign
{
    msgbox("Castelia City Pokémon Gym\n"
        "Leader: Burgh\l"
        "Premier Insect Artist", MSGBOX_SIGN)
    end
}

script CasteliaCity_GymStreet_EventScript_Trigger_InFronOfGym
{
    lock
	applymovement(LOCALID_PLAYER, moves(face_right))
	waitmovement(0)
	playse(SE_PIN)
	applymovement(LOCALID_PLAYER, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	playse(SE_EXIT)
	addobject(LOCALID_CCGS_CHEREN)
	waitse()
	delay(10)
	applymovement(LOCALID_CCGS_CHEREN, moves(walk_left * 3))
	applymovement(LOCALID_PLAYER, moves(walk_left * 3, walk_in_place_right))
	waitmovement(0)
	delay(10)
    msgbox("Cheren: Hey, {PLAYER}.\n"
           "I just challenged the Gym Leader Burgh.", MSGBOX_DEFAULT, TRUE, LOCALID_CCGS_CHEREN)
    destroy_speech_bubble()
    closemessage
	applymovement(LOCALID_CCGS_CHEREN, moves(walk_in_place_right))
	waitmovement(0)
	delay(10)
    msgbox("He's a seasoned Gym Leader.\n"
           "He made me work for that Gym Badge!\p"
           "But for me, Bug-type Pokémon\n"
           "aren't that much of a challenge.", MSGBOX_DEFAULT, TRUE, LOCALID_CCGS_CHEREN)
    destroy_speech_bubble()
    closemessage
	applymovement(LOCALID_CCGS_CHEREN, moves(face_left))
	waitmovement(0)
	delay(10)
    msgbox("I'm going to keep winning like this against\n"
           "all of the Unova region's Gym Leaders!\p"
           "Then, I'll head for the Pokémon League\n"
           "and outperform the Champion!\p"
           "If I do that, everyone will admit\n"
           "what a strong Trainer I am...\p"
           "That will make me feel truly alive...", MSGBOX_DEFAULT, TRUE, LOCALID_CCGS_CHEREN)
    destroy_speech_bubble()
    closemessage
	applymovement(LOCALID_PLAYER, moves(walk_in_place_down))
	applymovement(LOCALID_CCGS_CHEREN, moves(walk_down * 6))
	waitmovement(0)
    removeobject(LOCALID_CCGS_CHEREN)
    delay(20)
	playse(SE_EXIT)
	addobject(LOCALID_CCGS_BURGH)
	waitse()
	delay(10)
	applymovement(LOCALID_CCGS_BURGH, moves(walk_fast_left * 3))
	waitmovement(0)
	playse(SE_PIN)
	applymovement(LOCALID_CCGS_BURGH, moves(emote_exclamation_mark))
	waitmovement(0)
	waitse()
	delay(20)
	applymovement(LOCALID_PLAYER, moves(face_right))
	waitmovement(0)
    msgbox("Burgh: Ah hah!\p"
           "You're the one who fought\n"
           "Team Plasma in Pinwheel Forest...\p"
           "If I remember, your name is...\n"
           "{PLAYER}!\p"
           "Come to challenge the Gym, I suppose?\p"
           "Aww. Sorry, but could you wait a bit?\p"
           "I was informed that Team Plasma\n"
           "has shown up!\p"
           "In fact... Come with me!\n"
           "I'm going to the dock at Primer Pier!", MSGBOX_DEFAULT, TRUE, LOCALID_CCGS_BURGH)
    destroy_speech_bubble()
    closemessage
	applymovement(LOCALID_PLAYER, moves(walk_in_place_down))
	applymovement(LOCALID_CCGS_BURGH, moves(walk_fast_down * 6))
	waitmovement(0)
    removeobject(LOCALID_CCGS_BURGH)
    clearflag(FLAG_CASTELIA_PRIME_PIER_CROWD)
    clearflag(FLAG_CASTELIA_PRIME_PIER_BURGH)
    clearflag(FLAG_ROUTE4_SOUTH_CHEREN)
    setvar(VAR_CASTELIA_GYM_STATE, 1)
    delay(20)
    release
    end
}

script CasteliaCity_GymStreet_EventScript_Trigger_InFronOfEmptyBuilding_Pos1
{
    lock
	applymovement(LOCALID_PLAYER, moves(walk_right * 3, walk_down * 2, walk_left))
	waitmovement(0)
    goto(CasteliaCity_GymStreet_EventScript_Trigger_ThisIsThePlace)
}

